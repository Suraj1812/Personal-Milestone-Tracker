{
  "name": "personal-milestone-tracker",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "concurrently -n API,WEB -c blue,green \"npm run dev --workspace server\" \"npm run dev --workspace client\"",
    "dev:server": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "build": "npm run build --workspace client && npm run build --workspace server",
    "test": "npm run test --workspace server",
    "start": "npm run start --workspace server",
    "verify:e2e": "npm run build && node scripts/verify-e2e.mjs"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
